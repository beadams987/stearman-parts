{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "eslint src/ --fix --quiet 2>/dev/null; tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prebuild": "npx tsc --noEmit 2>&1 | grep TS6133 | while read line; do file=$(echo \"$line\" | cut -d\"(\" -f1); import=$(echo \"$line\" | grep -oP \"'[^']+'\"); echo \"Unused: $import in $file\"; done || true",
    "lint:fix": "eslint src/ --fix || true"
  },
  "dependencies": {
    "@microsoft/applicationinsights-react-js": "^19.4.0",
    "@microsoft/applicationinsights-web": "^3.4.1",
    "@tanstack/react-query": "^5.90.21",
    "@workos-inc/authkit-react": "^0.16.0",
    "axios": "^1.13.6",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.2",
    "vitest": "^4.0.0"
  }
}
